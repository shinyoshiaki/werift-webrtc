{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": [
      "esnext",
      "DOM"
    ],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals",
      "vite/client"
    ],
    "moduleResolution": "bundler"
  },
  "include": [
    "tests"
  ]
}
