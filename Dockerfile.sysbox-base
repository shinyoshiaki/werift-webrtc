FROM nestybox/ubuntu-noble-systemd-docker
ENV DEBIAN_FRONTEND=noninteractive
ARG HOST_UID=1000
ARG HOST_GID=1000
RUN apt-get update \
  && apt-get install -y bash ca-certificates curl dbus dbus-user-session git gnome-keyring gnupg libsecret-1-0 libsecret-tools sudo uidmap libavdevice-dev libavfilter-dev libopus-dev libvpx-dev pkg-config libsrtp2-dev libasound2-dev libgstreamer1.0-0 gstreamer1.0-plugins-base gstreamer1.0-plugins-good gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav gstreamer1.0-tools gstreamer1.0-x gstreamer1.0-alsa gstreamer1.0-pulseaudio \
  && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
  && apt-get install -y nodejs \
  && npm install -g @anthropic-ai/claude-code @google/gemini-cli @github/copilot @openai/codex opencode-ai \
  && rm -rf /var/lib/apt/lists/*
RUN set -eux; \
  docker_socket=""; \
  if [ -S /var/run/docker.sock ]; then \
    docker_socket=/var/run/docker.sock; \
  elif [ -S /run/docker.sock ]; then \
    docker_socket=/run/docker.sock; \
  fi; \
  if ! getent group "$HOST_GID" >/dev/null; then \
    if getent group sakhost >/dev/null; then \
      groupmod -g "$HOST_GID" sakhost; \
    else \
      groupadd --gid "$HOST_GID" sakhost; \
    fi; \
  fi; \
  if ! getent passwd "$HOST_UID" >/dev/null; then \
    if id -u sak >/dev/null 2>&1; then \
      usermod -u "$HOST_UID" -g "$HOST_GID" -m sak; \
    else \
      useradd --uid "$HOST_UID" --gid "$HOST_GID" -m -s /bin/bash sak; \
    fi; \
  fi; \
  runtime_user="$(getent passwd "$HOST_UID" | cut -d: -f1 || true)"; \
  if [ -z "$runtime_user" ]; then \
    echo "Failed to resolve runtime user for HOST_UID=$HOST_UID" >&2; \
    exit 1; \
  fi; \
  docker_group="docker"; \
  if [ -n "$docker_socket" ]; then \
    docker_gid="$(stat -c '%g' "$docker_socket")"; \
    existing_docker_group="$(getent group "$docker_gid" | cut -d: -f1 || true)"; \
    if [ -n "$existing_docker_group" ]; then \
      docker_group="$existing_docker_group"; \
    elif getent group "$docker_group" >/dev/null; then \
      groupmod -g "$docker_gid" "$docker_group"; \
    else \
      groupadd --gid "$docker_gid" "$docker_group"; \
    fi; \
  elif ! getent group "$docker_group" >/dev/null; then \
    groupadd "$docker_group"; \
  fi; \
  usermod -aG "$docker_group" "$runtime_user"; \
  mkdir -p /workspace /var/lib/docker; \
  chown -R "$HOST_UID:$HOST_GID" /workspace /var/lib/docker; \
  user_home="$(getent passwd "$HOST_UID" | cut -d: -f6 || true)"; \
  if [ -n "$user_home" ] && [ -d "$user_home" ]; then \
    chown -R "$HOST_UID:$HOST_GID" "$user_home"; \
  fi
WORKDIR /workspace

  CMD ["/sbin/init"]
